{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@particle-academy/react-fancy": ["./packages/react-fancy/src"],
      "@particle-academy/fancy-echarts": ["./packages/fancy-echarts/src"],
      "@particle-academy/fancy-code": ["./packages/fancy-code/src"],
      "@particle-academy/fancy-sheets": ["./packages/fancy-sheets/src"]
    }
  },
  "include": ["resources/js/**/*.ts", "resources/js/**/*.tsx"]
}
